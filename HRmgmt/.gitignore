# 1. Ignore EVERYTHING in the project by default
/*

# 2. Re-allow the specific folders we need
!/Database/
!/Frontend/
!/Backend/

# 3. Specifically allow only your 4 important files
!/Database/database_setup.sql
!/Frontend/index.html
!/Backend/app.js
!/Backend/package.json

# 4. Also allow the .gitignore itself so people can see your clean setup
!.gitignore